# ==============================================
# LinkUp Staging Environment Configuration
# ==============================================

# Application
NODE_ENV=staging
NEXT_PUBLIC_APP_URL=https://staging.linkup.app
APP_NAME=LinkUp Staging

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-staging-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_REF=your-staging-ref
SUPABASE_DB_PASSWORD=your-db-password

# Authentication
JWT_SECRET=your-jwt-secret-min-32-chars
CRON_SECRET=your-cron-secret
EDGE_FUNCTION_SECRET=your-edge-function-secret

# External Services
MAPBOX_TOKEN=your-mapbox-token
POSTHOG_KEY=your-posthog-key
SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your-bot-username

# Storage
STORAGE_BUCKET_AVATARS=avatars
STORAGE_BUCKET_EVENTS=events
STORAGE_BUCKET_MESSAGES=messages

# Push Notifications
PUSH_VAPID_KEY=your-vapid-public-key
PUSH_PRIVATE_KEY=your-vapid-private-key

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_ERROR_TRACKING=true
ENABLE_PERFORMANCE_MONITORING=true

# Performance
DEBUG=false
LOG_LEVEL=info
API_LOGGING=true
