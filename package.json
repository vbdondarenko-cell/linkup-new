{
  "name": "linkup",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=src/domain --coverage",
    "test:integration": "jest --testPathPattern=integration --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:coverage": "jest --coverage --coverageReporters=lcov,html",
    "test:smoke": "playwright test --grep=@smoke",
    "test:regression": "playwright test --grep=@regression",
    "test:accessibility": "playwright test --grep=@a11y",
    "check:unused": "ts-prune --project tsconfig.json 2>/dev/null | head -20 || echo 'No unused exports'",
    "check:circular": "madge --circular src/**/*.ts 2>/dev/null || echo 'Circular dependency check skipped'",
    "analyze:bundle": "ANALYZE=true npm run build",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:generate-types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF > supabase/types/database.ts",
    "clean": "rm -rf .next node_modules/.cache coverage"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-native": "^0.75.0",
    "@supabase/supabase-js": "^2.45.0",
    "@supabase/realtime-js": "^2.10.0",
    "zustand": "^5.0.0",
    "react-hook-form": "^7.53.0",
    "@hookform/resolvers": "^3.9.0",
    "zod": "^3.23.0",
    "date-fns": "^3.6.0",
    "react-native-reanimated": "^3.16.0",
    "@tanstack/react-query": "^5.56.0",
    "axios": "^1.7.0",
    "uuid": "^10.0.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.5.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.2.0",
    "jest-environment-jsdom": "^29.7.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/user-event": "^14.5.0",
    "@testing-library/react-native": "^12.8.0",
    "react-test-renderer": "^18.3.0",
    "playwright": "^1.48.0",
    "@playwright/test": "^1.48.0",
    "axe-core": "^4.10.0",
    "axe-playwright": "^2.0.0",
    "lighthouse": "^12.2.0",
    "@lhci/cli": "^0.14.0",
    "k6": "^0.52.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0",
    "madge": "^7.0.0",
    "ts-prune": "^0.10.0",
    "bundle-analyzer": "^0.1.0",
    "@next/bundle-analyzer": "^14.2.0",
    "git-hooks": "^1.1.0",
    "lint-staged": "^15.2.0",
    "husky": "^9.1.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "\\.(css|less|scss|sass)$": "identity-obj-proxy"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/src/__tests__/setup.ts"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/*.stories.tsx",
      "!src/**/index.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "playwright": {
    "testDir": "tests/e2e",
    "timeout": 30000,
    "retries": 2,
    "workers": null,
    "use": {
      "baseURL": "http://localhost:3000",
      "trace": "on-first-retry",
      "screenshot": "only-on-failure",
      "video": "retain-on-failure"
    },
    "projects": [
      {
        "name": "chromium",
        "use": { "browserName": "chromium" }
      },
      {
        "name": "firefox",
        "use": { "browserName": "firefox" }
      },
      {
        "name": "webkit",
        "use": { "browserName": "webkit" }
      }
    ],
    "reporter": [
      ["html", { "outputFolder": "playwright-report" }],
      ["json", { "outputFile": "test-results/e2e-results.json" }],
      ["list"]
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
